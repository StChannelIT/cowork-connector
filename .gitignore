# Config con dati reali (token, URL) — non va committato
cowork_domains.json

# Credenziali FTP/SFTP per il deploy di tasks.php (opzionale, solo se
# l'utente ha chiesto di persisterle) — non va committato
deploy_access.json

# Connessioni reali dell'utente (config/note/DB locali per-connessione) —
# resta solo la convenzione (connections/README.md, connections/.gitkeep)
connections/*/

# Stato locale generato a runtime
backups/
covers/
assets/
*.db
*.db-journal
cowork_completions.json
cowork_local_queue.db

# Python
__pycache__/
*.pyc
.venv/

# OS
.DS_Store
Thumbs.db

# Local Claude Code harness state (settings, worktrees) — machine/session
# specific, never part of the tracked tree
.claude/

# Local, non-shared process instructions for Claude Code (commit/versioning
# rules) — not part of the public project docs
CLAUDE.local.md
